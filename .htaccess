# Force no-cache on HTML and version.json so updates reach users immediately
<FilesMatch "\.(html|htm)$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</FilesMatch>
<FilesMatch "version\.json$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>

# Allow long-term caching on JS/CSS/images (cache busted via version reload)
<FilesMatch "\.(js|css|png|jpg|jpeg|svg|webp|woff2?)$">
  Header set Cache-Control "public, max-age=31536000"
</FilesMatch>
